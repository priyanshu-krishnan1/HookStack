# Shared application settings
WEBHOOK_SECRET=change-me
WEBHOOK_PROVIDER=generic
PORT=4000
MAX_RETRIES=3
RETRY_DELAY_MS=1000
WORKER_PREFETCH=10

# Infrastructure settings
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db
RABBITMQ_URL=amqp://app_user:app_password@localhost:5672
RABBITMQ_EXCHANGE=app.events
RABBITMQ_QUEUE=app.events.processing
RABBITMQ_DLX=app.events.dlx
RABBITMQ_DLQ=app.events.dead
RABBITMQ_ROUTING_KEY=app.event.process

# Sender settings
WEBHOOK_URL=http://localhost:4000/webhook
EVENT_COUNT=1
SENDER_CONCURRENCY=1
EVENT_TYPE=sample.event.created
MIXED_EVENT_TYPES=false

# Worker settings
WORKER_ID=worker-1